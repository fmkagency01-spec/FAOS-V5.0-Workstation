# Production frontend → Render backend mapping
# Set these in Vercel → Project → Settings → Environment Variables
# CRITICAL: no trailing slash on the backend URL. Never commit real secrets.

NEXT_PUBLIC_BACKEND_URL=https://faos-backend.onrender.com/api/v5
NEXT_PUBLIC_FAOS_BACKEND_URL=https://faos-backend.onrender.com/api/v5
NEXT_PUBLIC_API_VERSION=v5.3
NEXT_PUBLIC_SITE_URL=https://faos-v5-0-workstation.vercel.app

# Server-only — set OPENROUTER_API_KEY in Vercel dashboard, not in this file
OPENROUTER_API_KEY=your_openrouter_api_key_here
