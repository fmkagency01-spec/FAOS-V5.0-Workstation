# Copy values into Vercel → Project → Settings → Environment Variables (Production)
# CRITICAL: no trailing slash on backend URL

NEXT_PUBLIC_BACKEND_URL=https://faos-backend.onrender.com/api/v5
NEXT_PUBLIC_FAOS_BACKEND_URL=https://faos-backend.onrender.com/api/v5
NEXT_PUBLIC_API_VERSION=v5.0
NEXT_PUBLIC_SITE_URL=https://faos-v5-0-workstation.vercel.app

# Server-only — set in Vercel dashboard (Production + Preview), never commit a real key here
OPENROUTER_API_KEY=

# OpenRouter safety guard
OPENROUTER_MAX_DAILY_REQUESTS=100
OPENROUTER_ABORT_COMPLETION_TOKENS=5
