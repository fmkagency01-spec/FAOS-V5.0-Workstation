# Copy to .env.local for local Next.js development (never commit .env.local)

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Render Python backend — NO trailing slash
NEXT_PUBLIC_BACKEND_URL=https://faos-backend.onrender.com
NEXT_PUBLIC_FAOS_BACKEND_URL=https://faos-backend.onrender.com
NEXT_PUBLIC_API_VERSION=v5.0

# Server-only — set in .env.local for local /api/chat testing
OPENROUTER_API_KEY=
