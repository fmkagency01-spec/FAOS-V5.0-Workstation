# Copy to .env.local for local development (never commit .env.local)

# Public site URL (used for OpenRouter HTTP-Referer header)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only secret — set the real value in:
#   1) local .env.local
#   2) Vercel → Project → Settings → Environment Variables
# NEVER commit a real key to GitHub.
OPENROUTER_API_KEY=
