# Copy to .env.local for local development (never commit real secrets)

# Public site URL (used for OpenRouter HTTP-Referer header)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Render Python backend (FastAPI). When set, Next.js /api/create-pillar proxies here.
# Example: https://faos-backend.onrender.com
NEXT_PUBLIC_FAOS_BACKEND_URL=
NEXT_PUBLIC_API_VERSION=v5.0

# Server-only secrets — set in Vercel / Render dashboards, never commit.
OPENROUTER_API_KEY=

# Optional Create Pillar / Gatekeeper TAC endpoint
TAC_CENTRAL_CORE_URL=https://tac.fmk-ecosystem.internal/approve
