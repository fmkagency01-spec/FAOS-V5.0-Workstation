# Copy to .env.local for local development (never commit .env.local)

# Public site URL (used for OpenRouter HTTP-Referer header)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only secrets — set real values in:
#   1) local .env.local
#   2) Vercel → Project → Settings → Environment Variables
# NEVER commit real keys to GitHub.
OPENROUTER_API_KEY=

# Optional Create Pillar / Gatekeeper TAC endpoint
TAC_CENTRAL_CORE_URL=https://tac.fmk-ecosystem.internal/approve
