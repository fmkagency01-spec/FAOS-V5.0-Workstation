# Copy to .env.local for local development (never commit real secrets)

# Public site URL (OpenRouter HTTP-Referer)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Render Python backend base URL — NO trailing slash
# Example: https://faos-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=https://faos-backend.onrender.com
# Backward-compatible alias (either name works):
NEXT_PUBLIC_FAOS_BACKEND_URL=https://faos-backend.onrender.com
NEXT_PUBLIC_API_VERSION=v5.0

# Server-only secrets — set in Vercel / Render dashboards, never commit.
OPENROUTER_API_KEY=

# OpenRouter abuse guard (prevents automation token drain loops)
OPENROUTER_MAX_REQUESTS_PER_MINUTE=6
OPENROUTER_MAX_REQUESTS_PER_HOUR=60
OPENROUTER_MAX_REQUESTS_TOTAL=100
OPENROUTER_MIN_COMPLETION_TOKENS=10
OPENROUTER_LOW_TOKEN_STRIKE_LIMIT=3
OPENROUTER_CIRCUIT_COOLDOWN_MS=300000

# Optional Create Pillar / Gatekeeper TAC endpoint
TAC_CENTRAL_CORE_URL=https://tac.fmk-ecosystem.internal/approve
