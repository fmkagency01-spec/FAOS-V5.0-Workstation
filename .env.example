# Copy to .env.local for local development (never commit real secrets)

# Public site URL (OpenRouter HTTP-Referer)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Render Python backend v5 API base — NO trailing slash
NEXT_PUBLIC_BACKEND_URL=https://faos-backend.onrender.com/api/v5
NEXT_PUBLIC_FAOS_BACKEND_URL=https://faos-backend.onrender.com/api/v5
NEXT_PUBLIC_API_VERSION=v5.2

# --- Authentication (Phase 5 — set in Vercel for production) ---
FAOS_AUTH_SECRET=
FAOS_OWNER_PASSWORD=
# FAOS_AUTH_USERS=[{"username":"fahim","password":"xxx","name":"Fahim Mahmud Khan","role":"owner"}]

# Server-only secrets — set in Vercel / Render dashboards, never commit.
OPENROUTER_API_KEY=
FAOS_BACKEND_API_KEY=

# Notifications (Resend preferred, SMTP fallback, file/console outbox last)
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
FAOS_NOTIFY_FROM=noreply@faos.local
FAOS_NOTIFY_DEFAULT_TO=

# API rate limits (Next.js routes)
FAOS_API_MAX_PER_MINUTE=30
FAOS_API_MAX_PER_HOUR=300
FAOS_BACKEND_MAX_PER_MINUTE=120
# On Render: set FAOS_REQUIRE_BACKEND_API_KEY=true to fail closed if key missing
FAOS_REQUIRE_BACKEND_API_KEY=

# Phase 4 — image generation model (OpenRouter Flux)
FAOS_IMAGE_MODEL=black-forest-labs/flux-1.1-pro

# OpenRouter abuse guard
FAOS_TOKEN_SAVING_MODE=true
FAOS_MAX_OUTPUT_TOKENS=280
OPENROUTER_MAX_DAILY_REQUESTS=100
OPENROUTER_MAX_REQUESTS_PER_MINUTE=6
OPENROUTER_MAX_REQUESTS_PER_HOUR=60
OPENROUTER_ABORT_COMPLETION_TOKENS=5
OPENROUTER_LOW_TOKEN_STRIKE_LIMIT=3
OPENROUTER_CIRCUIT_COOLDOWN_MS=300000

TAC_CENTRAL_CORE_URL=https://tac.fmk-ecosystem.internal/approve

# ERP ↔ TAC intelligence thresholds
FAOS_HIGH_VALUE_INVOICE_THRESHOLD=1000
FAOS_MAJOR_INVENTORY_DELTA=25
FAOS_TAC_INSIGHT_MODEL=openai/gpt-4o-mini

